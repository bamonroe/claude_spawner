# Production image for the claude_spawner server in BROKER mode.
#
# Unlike ./Dockerfile (the old all-in-one dev image that executed claude itself),
# this image is lean: it carries ONLY the compiled server binary and ffmpeg (for
# decoding the app's Ogg/Opus audio). It runs NO claude, podman, or tmux — all
# turn execution is delegated to the host-side broker (cmd/broker) over a
# bind-mounted Unix socket, so the container stays unprivileged and needs no
# host root or container-runtime socket. Transcription is remote (SPAWNER_WHISPER_URL).
#
#   docker build -f server/Dockerfile.broker -t spawner-server server

ARG GO_VERSION=1.23
FROM golang:${GO_VERSION}-bookworm AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
# Static binary so the runtime image needs no Go/glibc specifics.
RUN CGO_ENABLED=0 go build -trimpath -o /out/spawner .

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
        ffmpeg ca-certificates \
    && rm -rf /var/lib/apt/lists/*
COPY --from=build /out/spawner /usr/local/bin/spawner
# Non-root, uid 1000 to line up with host-owned read-only mounts (roots, ~/.claude).
RUN useradd -m -u 1000 -s /bin/bash app
USER app
ENV HOME=/home/app SPAWNER_FFMPEG_BIN=ffmpeg
EXPOSE 8080
ENTRYPOINT ["/usr/local/bin/spawner"]
