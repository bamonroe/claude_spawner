# Compose variable overrides. Copy to .env (git-ignored) and set to your own uid/gid
# so the containerized server runs as you and can read/write the mounted home, state,
# and project roots:
#
#   cp .env.example .env
#   printf 'SPAWNER_UID=%s\nSPAWNER_GID=%s\n' "$(id -u)" "$(id -g)" > .env
#
# docker compose auto-loads .env from this directory, so `docker compose up -d --build`
# then needs no prefix. (HOME is inherited from your shell.)
SPAWNER_UID=1000
SPAWNER_GID=1000

# Host directory holding the whisper ggml models. Mounted into both containers at the
# SAME path, so it must match SPAWNER_WHISPER_MODELS_DIR in deploy/spawner-container.env
# (the gateway reads the models at this path inside its container). Defaults to
# /data/storage/whisper if unset.
SPAWNER_WHISPER_MODELS_DIR=/data/storage/whisper
