# Environment for the containerized SSH-native server (the spawner-server service in
# the root docker-compose.yml).
# Copy to spawner-container.env and fill in. All vars are documented in CLAUDE.md.
# EDIT EVERY VALUE CONTAINING `you` — they are placeholders for YOUR host login user
# and home; nothing here is auto-detected.

# The HOST user's home directory. Nothing is mounted — the server reaches all files
# over SSH — but HOME anchors where it looks for Claude/Codex state on the host and
# where the sandbox's same-path home mount lands. Must match SPAWNER_SSH_USER's home.
HOME=/home/you

# Auth — required. Use a strong token; the app presents it in the hello handshake.
# The literal `change-me` is rejected at startup, so you must actually change it.
SPAWNER_TOKEN=change-me

# Listen address the gateway binds on the host (host networking). Point the app here.
SPAWNER_ADDR=:8098

# Spawn-dir jail (colon-separated HOST paths). Spoken spawn locations are matched
# against these; the visual picker isn't jailed. Reached over SSH — no mount needed.
SPAWNER_ROOT=/data:/home/you

# Durable state, kept on the ./state volume (out of the image). Identities and their
# private keys go here too — must be a WRITABLE mounted path, not the default relative
# path (the container's working dir is read-only to the run-as user).
SPAWNER_STATE=/state/sessions.json
# Optional execution-profile catalogue (see deploy/profiles.example.json for locked/open presets).
# Missing file = only the built-in 'default' profile, seeded from the SPAWNER_SANDBOX_* vars below.
SPAWNER_PROFILES=/state/profiles.json
# Global template vars for profiles: a JSON object of strings, referenced in a profile as
# {{.Vars.Name}} (a profile's own "vars" override these). Built-ins {{.Home}} {{.Session}} {{.Dir}}
# are always available. Referencing an undefined var fails the turn. Empty = no global vars.
SPAWNER_PROFILE_VARS={"OllamaHost":"pickle.bam.net"}
SPAWNER_HOSTS=/state/hosts.json
SPAWNER_IDENTITIES=/state/identities.json
SPAWNER_SSH_KEYS=/state/ssh_keys

# SSH-native execution is unconditional: every host-target turn runs over SSH. With
# host networking, the loopback host dials localhost:22 — the host's own sshd — so the
# container drives the host.
#
# The server owns its OWN SSH keypair, separate from the host's ~/.ssh keys, and
# self-manages it: leave SPAWNER_SSH_KEY empty and on first boot the server MINTS an
# ed25519 key at /state/ssh/id_ed25519 (persisted on the volume) and writes the public
# key to /state/ssh/id_ed25519.pub (also logged at startup). To let the container SSH
# into the host — for host turns AND the restart button — add that public key to the
# login user's ~/.ssh/authorized_keys on the host, e.g.:
#     cat deploy/state/ssh/id_ed25519.pub >> ~/.ssh/authorized_keys
# known_hosts (/state/known_hosts, the server's own trust set, NOT the host's) is
# auto-seeded: the loopback host key is trusted on first boot, and app-added hosts are
# trusted when saved. Nothing needs to be placed or ssh-keyscanned by hand.
#
# SPAWNER_SSH_USER is the HOST login the server SSHes in as (host turns, restart,
# transcript reads all run as this user) — set it to YOUR username. The host must be
# running sshd with public-key auth enabled.
SPAWNER_SSH_USER=you
SPAWNER_SSH_KEY=
SPAWNER_SSH_KNOWN_HOSTS=/state/known_hosts

# Speech-to-text via the resident whisper.cpp service (the whisper container in the same
# compose file, on host networking). SPAWNER_WHISPER_URL points the gateway at it.
# SPAWNER_WHISPER_MODELS_DIR is the HOST directory of ggml model files that the whisper
# container mounts at /models; its model names are offered to clients as a settings
# picker. Adjust to where you keep your models, keep it matched with the root .env's
# copy (compose mounts it), and CREATE it as your user before the first `up` — if Docker
# creates it for you it'll be root-owned and the gateway can't download models into it.
# Optional second fast/draft server: uncomment and run a second whisper container on
# :8572 (see whisper/README.md).
SPAWNER_WHISPER_URL=http://localhost:8571
#SPAWNER_WHISPER_FAST_URL=http://localhost:8572
SPAWNER_WHISPER_MODELS_DIR=/data/storage/whisper

# Server-side speech synthesis (optional): the kokoro compose service on :8880
# (shares the GPU with whisper). Leave SPAWNER_TTS_URL unset to disable — clients
# then use their on-device voices. Voice ids: GET /v1/audio/voices, or the app's
# audio-settings picker once connected.
SPAWNER_TTS_URL=http://localhost:8880
#SPAWNER_TTS_VOICE=af_heart
#SPAWNER_TTS_FORMAT=opus

# Sandbox target (per-session target: sandbox) — DISABLED by default (empty image):
# enabling it requires rootless podman on the host and the sandbox image built first
# (podman build … per sandbox/README.md); with it enabled but missing, spawns that pick
# the sandbox just fail. The server container has no runtime of its own, so sandbox
# turns drive rootless podman on the HOST over the same SSH pool as host turns — every
# path below is a HOST path. Set the image to spawner-sandbox:latest once built.
SPAWNER_SANDBOX_IMAGE=
SPAWNER_SANDBOX_RUNTIME=podman
# Each backend's binary + auth is mounted in from the host (the image ships neither):
# claude via /opt/claude-code + /usr/bin/claude + ~/.claude(.json) (an Arch claude-code
# package layout — adjust to where YOUR claude lives); codex via ~/.codex (which holds
# the standalone binary, auth.json, and the sessions dir). Both ~/.claude and ~/.codex
# are mounted read-write so the sandbox writes transcripts back to the same host dirs
# the server reads them from.
SPAWNER_SANDBOX_MOUNTS=/opt/claude-code:/opt/claude-code:ro,/usr/bin/claude:/usr/bin/claude:ro,/home/you/.claude:/home/you/.claude,/home/you/.claude.json:/home/you/.claude.json,/home/you/.codex:/home/you/.codex
# Absolute path to the codex binary INSIDE the sandbox (i.e. inside the mounted ~/.codex),
# so it's found regardless of the container's PATH. `codex` on the host's ~/.local/bin is
# usually a symlink into this packages dir — point at the resolved target.
SPAWNER_SANDBOX_CODEX_BIN=/home/you/.codex/packages/standalone/current/bin/codex
SPAWNER_SANDBOX_RUN_ARGS=--userns=keep-id -e HOME=/home/you

# Web client — the built Compose/Wasm bundle served at / alongside /ws (one binary
# hosts both the browser client and the gateway). The bundle is baked into the image
# at /srv/web (deploy/rebuild-container.sh stages the Gradle output into the build
# context, so a `rebuild` ships the current client — no host mount). Build the bundle
# out-of-band when the UI changes: ./android/gradlew -p android :app:wasmJsBrowserDistribution
# Empty disables web serving.
SPAWNER_WEB_DIR=/srv/web

# Restart button — rebuild + recreate this container (one-tap deploy of new code).
# It must run on the HOST (recreating this container replaces it, so it can't run
# inside it). The server runs this command on the host over
# its own Go-native SSH connection (the same loopback login as turns) — no openssh
# client needed. Launch the rebuild DETACHED (setsid) so it survives the teardown.
# Empty disables the button. The `%REBUILD%` token is replaced by the server with
# `rebuild` (full --no-cache recompile) or `bounce` (fast recreate from the existing
# image) per the app's checkbox; keep it so the checkbox works. A command without the
# token always rebuilds.
# REPLACE /path/to/claude_spawner with your checkout's absolute path (the script itself
# is path-agnostic, but this command runs on the host so it needs the real location; a
# wrong path fails silently — output only lands in /tmp/spawner-rebuild.log).
SPAWNER_RESTART_CMD=setsid /path/to/claude_spawner/deploy/rebuild-container.sh %REBUILD% >/tmp/spawner-rebuild.log 2>&1 </dev/null &
