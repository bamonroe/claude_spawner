# Environment for the containerized SSH-native server (the spawner-server service in
# the root docker-compose.yml).
# Copy to spawner-container.env and fill in. All vars are documented in CLAUDE.md.

# HOME must match the mounted home path so ~/.claude and ~/.ssh resolve inside the
# container to the host user's real files.
HOME=/home/bam

# Auth — required. Use a strong token; the app presents it in the hello handshake.
SPAWNER_TOKEN=change-me

# Listen address the gateway binds on the host (host networking). Point the app here.
SPAWNER_ADDR=:8098

# Spawn-dir jail (colon-separated). These paths must be mounted into the container.
SPAWNER_ROOT=/data:/home/bam

# Durable state, kept on the ./state volume (out of the image). Identities and their
# private keys go here too — must be a WRITABLE mounted path, not the default relative
# path (the container's working dir is read-only to the run-as user).
SPAWNER_STATE=/state/sessions.json
SPAWNER_HOSTS=/state/hosts.json
SPAWNER_IDENTITIES=/state/identities.json
SPAWNER_SSH_KEYS=/state/ssh_keys

# SSH-native execution: host-target turns run over SSH. With host networking, an
# empty Session.Host dials localhost:22 — the host's own sshd — so the container
# drives the host.
#
# The server owns its OWN SSH keypair, separate from the host's ~/.ssh keys, and
# self-manages it: leave SPAWNER_SSH_KEY empty and on first boot the server MINTS an
# ed25519 key at /state/ssh/id_ed25519 (persisted on the volume) and writes the public
# key to /state/ssh/id_ed25519.pub (also logged at startup). To let the container SSH
# into the host — for host turns AND the restart button — add that public key to the
# login user's ~/.ssh/authorized_keys on the host, e.g.:
#     cat deploy/state/ssh/id_ed25519.pub >> ~/.ssh/authorized_keys
# known_hosts (/state/known_hosts, the server's own trust set, NOT the host's) is
# auto-seeded: the loopback host key is trusted on first boot, and app-added hosts are
# trusted when saved. Nothing needs to be placed or ssh-keyscanned by hand.
SPAWNER_SSH=1
SPAWNER_SSH_USER=bam
SPAWNER_SSH_KEY=
SPAWNER_SSH_KNOWN_HOSTS=/state/known_hosts

# Sandbox target (per-session target: sandbox). The container has no runtime of its
# own, so sandbox turns drive rootless podman on the HOST over the same SSH pool as
# host turns. Every path below is a HOST path (podman runs there). Leave the image
# empty to disable the sandbox target. HOME above must match the host user's home so
# the same-path home mount lands correctly.
SPAWNER_SANDBOX_IMAGE=spawner-sandbox:latest
SPAWNER_SANDBOX_RUNTIME=podman
SPAWNER_SANDBOX_MOUNTS=/opt/claude-code:/opt/claude-code:ro,/usr/bin/claude:/usr/bin/claude:ro,/home/bam/.claude:/home/bam/.claude,/home/bam/.claude.json:/home/bam/.claude.json
SPAWNER_SANDBOX_RUN_ARGS=--userns=keep-id -e HOME=/home/bam

# Web client — the built Compose/Wasm bundle served at / alongside /ws (one binary
# hosts both the browser client and the gateway). Point it at the bundle inside the
# container; the /data:/data mount makes the host build-output path resolve unchanged.
# Build it with: ./android/gradlew -p android :app:wasmJsBrowserDistribution
# Empty disables web serving.
SPAWNER_WEB_DIR=/data/claude_spawner/android/app/build/dist/wasmJs/productionExecutable

# Restart button — rebuild + recreate this container (one-tap deploy of new code).
# It must run on the HOST (recreating this container replaces it, so it can't run
# inside it): SSH to the host over loopback and launch the rebuild DETACHED (setsid) so
# it survives the teardown. Uses the same loopback login as turns. Empty disables the
# button. Requires the image built from the current Dockerfile (it ships openssh-client).
# The `%REBUILD%` token is replaced by the server with `rebuild` (full --no-cache
# recompile) or `bounce` (fast recreate from the existing image) per the app's checkbox;
# keep it so the checkbox works. A command without the token always rebuilds.
SPAWNER_RESTART_CMD=ssh -n -i /state/ssh/id_ed25519 -o UserKnownHostsFile=/state/known_hosts -o BatchMode=yes bam@localhost 'setsid /data/claude_spawner/deploy/rebuild-container.sh %REBUILD% >/tmp/spawner-rebuild.log 2>&1 </dev/null &'
