# claude_spawner server config (read by the systemd unit). Absolute paths only.
SPAWNER_TOKEN=changeme
SPAWNER_ADDR=:8555
SPAWNER_ROOT=/home/bam/git:/data
SPAWNER_STATE=/home/bam/.local/share/claude_spawner/sessions.json

# Transcription: default to the resident whisper container (docker compose up -d whisper).
SPAWNER_WHISPER_URL=http://localhost:8571
SPAWNER_WHISPER_FAST_URL=http://localhost:8572

# Local whisper.cpp fallback (used only if SPAWNER_WHISPER_URL is unset/blank).
SPAWNER_WHISPER_BIN=/home/bam/.local/bin/whisper-cli
SPAWNER_WHISPER_MODEL=/home/bam/.local/share/whisper/ggml-small.en.bin
SPAWNER_WHISPER_MODEL_FAST=/home/bam/.local/share/whisper/ggml-tiny.en.bin
SPAWNER_WHISPER_MODEL_BASE=/home/bam/.local/share/whisper/ggml-base.en.bin
SPAWNER_WHISPER_FAST_MAX_SEC=2.5
