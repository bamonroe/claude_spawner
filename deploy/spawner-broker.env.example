# Host-side broker config (read by deploy/spawner-broker.service). Absolute paths.
# The broker runs as your user and executes turns for the containerized server.

# Unix socket to listen on, in a PERSISTENT dir (not tmpfs /run) so the server
# container can bind-mount the directory and see the socket appear whenever the
# broker starts — no boot ordering dependency. Owner-only (0700 umask).
SPAWNER_BROKER_SOCKET=/home/you/.local/share/claude_spawner/broker/broker.sock

# Spawn jail (colon-separated, like PATH). MUST match the server's SPAWNER_ROOT,
# and these dirs must be mounted into the server container at the same paths.
SPAWNER_ROOT=/home/you/git:/data

# Host claude binary the broker forks for host turns.
SPAWNER_CLAUDE_BIN=claude

# --- Sandbox turns (optional; omit SPAWNER_SANDBOX_IMAGE to disable) ---
# The broker owns the runtime config (it, not the container, runs Podman). Build
# the image from sandbox/Containerfile. See sandbox/README.md for these values.
SPAWNER_SANDBOX_IMAGE=spawner-sandbox:latest
SPAWNER_SANDBOX_RUNTIME=podman
SPAWNER_SANDBOX_MOUNTS=/opt/claude-code:/opt/claude-code:ro,/usr/bin/claude:/usr/bin/claude:ro,/home/you/.claude:/home/you/.claude,/home/you/.claude.json:/home/you/.claude.json
SPAWNER_SANDBOX_RUN_ARGS=--userns=keep-id -e HOME=/home/you
