# claude_spawner server config (read by deploy/spawner-server.service). Absolute
# paths — a systemd user service has a minimal environment. The server runs bare
# metal as your user; it forks claude and drives Podman itself (no broker).

# Shared secret the app must present (required — the server refuses to start
# without it).
SPAWNER_TOKEN=changeme

# Listen address. The live deployment uses :8556; point the app here.
SPAWNER_ADDR=:8556

# Spawn jail (colon-separated, like PATH): sessions may only be created/searched
# under these roots.
SPAWNER_ROOT=/home/you/git:/data

# Durable session registry.
SPAWNER_STATE=/home/you/.local/share/claude_spawner/sessions.json

# Host claude binary forked for host turns (name on PATH or an absolute path).
SPAWNER_CLAUDE_BIN=claude

# Resident whisper servers (docker compose up -d whisper whisper-fast). Accurate
# on :8571, fast draft/detection on :8572.
SPAWNER_WHISPER_URL=http://localhost:8571
SPAWNER_WHISPER_FAST_URL=http://localhost:8572
SPAWNER_WHISPER_MODEL_NAME=large-v3

# Rebuild + relaunch command for the app's "restart" button. Fired via `sh -c` in
# its own process group so it survives the restart of this unit (which needs
# KillMode=process). Empty disables the restart button.
SPAWNER_RESTART_CMD=/data/claude_spawner/deploy/rebuild.sh

# --- Sandbox turns (optional; omit SPAWNER_SANDBOX_IMAGE to disable) ---
# The server drives the rootless runtime directly. Build the image from
# sandbox/Containerfile. See sandbox/README.md for these values.
SPAWNER_SANDBOX_IMAGE=spawner-sandbox:latest
SPAWNER_SANDBOX_RUNTIME=podman
SPAWNER_SANDBOX_MOUNTS=/opt/claude-code:/opt/claude-code:ro,/usr/bin/claude:/usr/bin/claude:ro,/home/you/.claude:/home/you/.claude,/home/you/.claude.json:/home/you/.claude.json
SPAWNER_SANDBOX_RUN_ARGS=--userns=keep-id -e HOME=/home/you
